{
  "expo": {
    "name": "MessengerApp",
    "slug": "messenger-app",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "允許應用訪問你的相冊以設定頭像",
          "cameraPermission": "允許應用訪問相機"
        }
      ],
      "expo-font"
    ]
  }
}
